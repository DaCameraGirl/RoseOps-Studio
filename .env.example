# RoseOps Studio — Enterprise Configuration

PORT=3099
HOST=0.0.0.0

# Required for production — protects all /api routes
ROSEOPS_API_KEY=your-secure-api-key-here

# Required — 32+ character encryption key for credentials vault
ROSEOPS_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-secret

# Optional database path (default: ./roseops.db)
# ROSEOPS_DB_PATH=/var/lib/roseops/roseops.db

# Execution engine
ROSEOPS_MAX_CONCURRENT_EXECUTIONS=10
ROSEOPS_DEFAULT_RETRIES=3
ROSEOPS_RETRY_DELAY_MS=1000
ROSEOPS_EXECUTION_TIMEOUT_MS=300000

# Rate limiting
ROSEOPS_RATE_LIMIT_WINDOW_MS=60000
ROSEOPS_RATE_LIMIT_MAX=300

# SMTP fallback (prefer SMTP credentials in vault)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@example.com
# SMTP_PASS=
# SMTP_FROM=RoseOps <notifications@example.com>

# CORS (set to your domain in production)
CORS_ORIGIN=*

LOG_LEVEL=info